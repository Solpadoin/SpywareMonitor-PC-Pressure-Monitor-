<Window x:Class="SpywareMonitor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC Pressure Monitor" Height="820" Width="1380" MinHeight="680" MinWidth="1080"
        Background="#090D17" Foreground="#EEF2FA" WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="Surface" Color="#111827"/><SolidColorBrush x:Key="Surface2" Color="#172033"/>
        <SolidColorBrush x:Key="Line" Color="#253047"/><SolidColorBrush x:Key="Muted" Color="#8996AC"/>
        <SolidColorBrush x:Key="Accent" Color="#6C7CFF"/><SolidColorBrush x:Key="Cyan" Color="#32C7D9"/>
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#EEF2FA"/></Style>
        <Style TargetType="Label"><Setter Property="Foreground" Value="#C7D0E1"/></Style>
        <Style x:Key="Card" TargetType="Border"><Setter Property="Background" Value="{StaticResource Surface}"/><Setter Property="CornerRadius" Value="14"/><Setter Property="Padding" Value="20"/><Setter Property="Margin" Value="0,0,14,14"/></Style>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#97A4BA"/><Setter Property="BorderThickness" Value="0"/><Setter Property="HorizontalContentAlignment" Value="Left"/><Setter Property="Padding" Value="18,13"/><Setter Property="Margin" Value="12,3"/><Setter Property="FontSize" Value="14"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="9" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" TextElement.Foreground="{TemplateBinding Foreground}"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Background" Value="#182237"/><Setter Property="Foreground" Value="#E8EDFA"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}"><Setter Property="Background" Value="#25315A"/><Setter Property="Foreground" Value="White"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="16,9"/><Setter Property="Margin" Value="0,0,8,0"/><Setter Property="Cursor" Value="Hand"/><Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="B" Property="Opacity" Value="0.84"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style TargetType="TextBox"><Setter Property="Background" Value="#0D1422"/><Setter Property="Foreground" Value="#EEF2FA"/><Setter Property="CaretBrush" Value="White"/><Setter Property="BorderBrush" Value="{StaticResource Line}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="10,8"/><Setter Property="FontSize" Value="14"/></Style>
        <Style TargetType="CheckBox"><Setter Property="Foreground" Value="#C7D0E1"/><Setter Property="Margin" Value="0,7"/><Setter Property="FontSize" Value="14"/><Setter Property="Cursor" Value="Hand"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="CheckBox"><StackPanel Orientation="Horizontal"><Border Width="18" Height="18" CornerRadius="4" Background="#0D1422" BorderBrush="#3B4862" BorderThickness="1"><TextBlock x:Name="Tick" Text="✓" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/></Border><ContentPresenter Margin="9,0,0,0" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}"/></StackPanel><ControlTemplate.Triggers><Trigger Property="IsChecked" Value="True"><Setter TargetName="Tick" Property="Visibility" Value="Visible"/><Setter TargetName="Tick" Property="Background" Value="Transparent"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.45"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
        <Style TargetType="DataGrid"><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#E8EDF7"/><Setter Property="BorderThickness" Value="0"/><Setter Property="RowBackground" Value="Transparent"/><Setter Property="AlternatingRowBackground" Value="#0D1422"/><Setter Property="GridLinesVisibility" Value="Horizontal"/><Setter Property="HorizontalGridLinesBrush" Value="#202B40"/><Setter Property="HeadersVisibility" Value="Column"/><Setter Property="AutoGenerateColumns" Value="False"/><Setter Property="RowHeight" Value="38"/><Setter Property="ColumnHeaderHeight" Value="40"/><Setter Property="SelectionMode" Value="Single"/></Style>
        <Style TargetType="DataGridColumnHeader"><Setter Property="Background" Value="#172136"/><Setter Property="Foreground" Value="#8F9CB1"/><Setter Property="Padding" Value="11"/><Setter Property="BorderThickness" Value="0"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
        <Style TargetType="DataGridCell"><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="10,0"/><Setter Property="VerticalContentAlignment" Value="Center"/></Style>
        <Style TargetType="DataGridRow"><Setter Property="Foreground" Value="#E8EDF7"/><Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#28375A"/><Setter Property="Foreground" Value="White"/></Trigger></Style.Triggers></Style>
        <Style TargetType="ListBoxItem"><Setter Property="Foreground" Value="#E8EDF7"/><Setter Property="Background" Value="Transparent"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#28375A"/><Setter Property="Foreground" Value="White"/></Trigger></Style.Triggers></Style>
        <Style TargetType="ProgressBar"><Setter Property="Height" Value="5"/><Setter Property="Maximum" Value="100"/><Setter Property="Background" Value="#242E42"/><Setter Property="BorderThickness" Value="0"/></Style>
        <Style x:Key="MetricLabel" TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource Muted}"/><Setter Property="FontSize" Value="12"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
        <Style x:Key="MetricValue" TargetType="TextBlock"><Setter Property="FontSize" Value="29"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Margin" Value="0,9,0,10"/></Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="230"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Background="#0D1422" BorderBrush="#1D273A" BorderThickness="0,0,1,0">
            <Grid><Grid.RowDefinitions><RowDefinition Height="92"/><RowDefinition/><RowDefinition Height="90"/></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="22,24,10,18">
                    <Border Width="42" Height="42" CornerRadius="11" Background="#6C7CFF"><TextBlock Text="P" FontSize="21" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    <StackPanel Margin="11,2,0,0"><TextBlock Text="PRESSURE" FontSize="16" FontWeight="Bold"/><TextBlock Text="MONITOR" Foreground="#71809A" FontSize="11" FontWeight="SemiBold"/></StackPanel>
                </StackPanel>
                <StackPanel Grid.Row="1">
                    <TextBlock Text="НАВИГАЦИЯ" Foreground="#526078" FontSize="10" FontWeight="Bold" Margin="29,16,0,8"/>
                    <Button x:Name="OverviewNav" Style="{StaticResource NavButtonActive}" Tag="0" Click="NavigationClick" Content="⌂   Обзор"/>
                    <Button x:Name="ProcessesNav" Style="{StaticResource NavButton}" Tag="1" Click="NavigationClick" Content="◉   Процессы"/>
                    <Button x:Name="EventsNav" Style="{StaticResource NavButton}" Tag="2" Click="NavigationClick" Content="≡   События"/>
                    <Button x:Name="SettingsNav" Style="{StaticResource NavButton}" Tag="3" Click="NavigationClick" Content="⚙   Настройки"/>
                </StackPanel>
                <Border Grid.Row="2" Margin="16" Padding="12" Background="#111B2C" CornerRadius="9">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#F05D6C" Margin="0,0,9,0"/><TextBlock x:Name="StatusText" Text="Подключение…" Foreground="#8996AC" FontSize="12" TextWrapping="Wrap"/></StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1"><Grid.RowDefinitions><RowDefinition Height="78"/><RowDefinition/></Grid.RowDefinitions>
            <Border BorderBrush="#1D273A" BorderThickness="0,0,0,1" Padding="28,0">
                <Grid><TextBlock x:Name="PageTitle" Text="Обзор системы" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/><StackPanel HorizontalAlignment="Right" VerticalAlignment="Center"><TextBlock Text="ЛОКАЛЬНЫЙ МОНИТОРИНГ" Foreground="#526078" FontSize="10" FontWeight="Bold"/><TextBlock Text="Данные никуда не отправляются" Foreground="#8996AC" FontSize="12" Margin="0,4,0,0"/></StackPanel></Grid>
            </Border>
            <TabControl x:Name="Tabs" Grid.Row="1" Background="Transparent" BorderThickness="0">
                <TabControl.Template><ControlTemplate TargetType="TabControl"><ContentPresenter ContentSource="SelectedContent"/></ControlTemplate></TabControl.Template>
                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="28,24,14,14">
                        <UniformGrid Columns="4">
                            <Border Style="{StaticResource Card}"><StackPanel><Grid><TextBlock Text="CPU" Style="{StaticResource MetricLabel}"/><Border HorizontalAlignment="Right" Width="30" Height="30" CornerRadius="8" Background="#222F5A"><TextBlock Text="%" Foreground="#8B9AFF" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></Grid><TextBlock x:Name="CpuText" Text="—" Style="{StaticResource MetricValue}"/><ProgressBar x:Name="CpuBar" Foreground="#6C7CFF"/></StackPanel></Border>
                            <Border Style="{StaticResource Card}"><StackPanel><Grid><TextBlock Text="ОПЕРАТИВНАЯ ПАМЯТЬ" Style="{StaticResource MetricLabel}"/><Border HorizontalAlignment="Right" Width="30" Height="30" CornerRadius="8" Background="#322650"><TextBlock Text="M" Foreground="#B88AFF" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></Grid><TextBlock x:Name="MemoryText" Text="—" Style="{StaticResource MetricValue}"/><ProgressBar x:Name="MemoryBar" Foreground="#A770FF"/></StackPanel></Border>
                            <Border Style="{StaticResource Card}"><StackPanel><Grid><TextBlock Text="ДИСКОВЫЙ I/O" Style="{StaticResource MetricLabel}"/><Border HorizontalAlignment="Right" Width="30" Height="30" CornerRadius="8" Background="#153946"><TextBlock Text="↕" Foreground="#32C7D9" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></Grid><TextBlock x:Name="IoText" Text="—" Style="{StaticResource MetricValue}"/><TextBlock x:Name="IoSubText" Foreground="{StaticResource Muted}" FontSize="12"/></StackPanel></Border>
                            <Border Style="{StaticResource Card}"><StackPanel><Grid><TextBlock Text="ПРОЦЕССЫ / ПОТОКИ" Style="{StaticResource MetricLabel}"/><Border HorizontalAlignment="Right" Width="30" Height="30" CornerRadius="8" Background="#263A32"><TextBlock Text="#" Foreground="#58D49C" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></Grid><TextBlock x:Name="ProcessText" Text="—" Style="{StaticResource MetricValue}"/><TextBlock Text="активны в текущем снимке" Foreground="{StaticResource Muted}" FontSize="12"/></StackPanel></Border>
                        </UniformGrid>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="2.25*"/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <Border Style="{StaticResource Card}"><StackPanel><Grid Margin="0,0,0,15"><TextBlock Text="Главные источники нагрузки" FontSize="17" FontWeight="SemiBold"/><TextBlock Text="по совокупному баллу давления" HorizontalAlignment="Right" Foreground="{StaticResource Muted}" FontSize="12"/></Grid><DataGrid x:Name="TopGrid" Height="390" IsReadOnly="True" SelectionChanged="ProcessSelectionChanged"><DataGrid.Columns><DataGridTextColumn Header="Процесс" Binding="{Binding Name}" Width="*"/><DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="70"/><DataGridTextColumn Header="CPU" Binding="{Binding CpuDisplay}" Width="80"/><DataGridTextColumn Header="RAM" Binding="{Binding MemoryDisplay}" Width="95"/><DataGridTextColumn Header="I/O" Binding="{Binding IoDisplay}" Width="95"/><DataGridTextColumn Header="Балл" Binding="{Binding ScoreDisplay}" Width="75"/></DataGrid.Columns></DataGrid></StackPanel></Border>
                            <Border Grid.Column="1" Style="{StaticResource Card}"><StackPanel><Grid Margin="0,0,0,15"><TextBlock Text="Сигналы" FontSize="17" FontWeight="SemiBold"/><Border HorizontalAlignment="Right" Background="#222F5A" CornerRadius="10" Padding="8,2"><TextBlock Text="LIVE" Foreground="#8B9AFF" FontSize="10" FontWeight="Bold"/></Border></Grid><ListBox x:Name="AlertsList" Background="Transparent" BorderThickness="0" Foreground="#E8EDF7"><ListBox.ItemTemplate><DataTemplate><Border Background="#172136" BorderBrush="#28344C" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,3"><StackPanel><TextBlock Text="{Binding Title}" TextWrapping="Wrap" FontWeight="SemiBold"/><TextBlock Text="{Binding Details}" TextWrapping="Wrap" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,4,0,0"/></StackPanel></Border></DataTemplate></ListBox.ItemTemplate></ListBox></StackPanel></Border>
                        </Grid>
                    </StackPanel></ScrollViewer>
                </TabItem>
                <TabItem>
                    <Grid Margin="28,24,14,24"><Grid.ColumnDefinitions><ColumnDefinition Width="2.5*"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource Card}"><DataGrid x:Name="ProcessesGrid" IsReadOnly="True" SelectionChanged="ProcessSelectionChanged" EnableRowVirtualization="True"><DataGrid.Columns><DataGridTextColumn Header="Процесс" Binding="{Binding Name}" Width="*"/><DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="65"/><DataGridTextColumn Header="CPU" Binding="{Binding CpuDisplay}" Width="75"/><DataGridTextColumn Header="RAM" Binding="{Binding MemoryDisplay}" Width="90"/><DataGridTextColumn Header="Private" Binding="{Binding PrivateDisplay}" Width="90"/><DataGridTextColumn Header="Чтение" Binding="{Binding ReadDisplay}" Width="85"/><DataGridTextColumn Header="Запись" Binding="{Binding WriteDisplay}" Width="85"/><DataGridTextColumn Header="Потоки" Binding="{Binding ThreadCount}" Width="70"/><DataGridTextColumn Header="Handles" Binding="{Binding HandleCount}" Width="75"/></DataGrid.Columns></DataGrid></Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}"><ScrollViewer><StackPanel><TextBlock Text="ДЕТАЛИ ПРОЦЕССА" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="DetailName" Text="Выберите процесс" FontSize="23" FontWeight="SemiBold" Margin="0,12,0,4"/><TextBlock x:Name="DetailPid" Foreground="{StaticResource Muted}"/><Border Height="1" Background="{StaticResource Line}" Margin="0,17"/><TextBlock Text="Путь" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="DetailPath" TextWrapping="Wrap" Margin="0,5,0,15"/><TextBlock Text="Командная строка" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="DetailCommand" TextWrapping="Wrap" Margin="0,5,0,15"/><TextBlock Text="Сетевые назначения" Style="{StaticResource MetricLabel}"/><ItemsControl x:Name="EndpointsList" Margin="0,6"/><Border Background="#0D1422" CornerRadius="9" Padding="13" Margin="0,14,0,0"><TextBlock x:Name="DetailStats" TextWrapping="Wrap" LineHeight="22"/></Border></StackPanel></ScrollViewer></Border>
                    </Grid>
                </TabItem>
                <TabItem><Border Style="{StaticResource Card}" Margin="28,24,28,24"><DataGrid x:Name="EventsGrid" IsReadOnly="True"><DataGrid.Columns><DataGridTextColumn Header="Время" Binding="{Binding TimeDisplay}" Width="150"/><DataGridTextColumn Header="Событие" Binding="{Binding KindDisplay}" Width="100"/><DataGridTextColumn Header="Процесс" Binding="{Binding Name}" Width="180"/><DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="70"/><DataGridTextColumn Header="Родитель" Binding="{Binding ParentProcessId}" Width="85"/><DataGridTextColumn Header="Путь / команда" Binding="{Binding Description}" Width="*"/></DataGrid.Columns></DataGrid></Border></TabItem>
                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"><Grid Margin="28,24,28,24" MaxWidth="1080" HorizontalAlignment="Left"><Grid.ColumnDefinitions><ColumnDefinition Width="380"/><ColumnDefinition Width="30"/><ColumnDefinition Width="620"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource Card}" Margin="0"><StackPanel><TextBlock Text="Сбор данных" FontSize="19" FontWeight="SemiBold"/><TextBlock Text="Частота и глубина фонового мониторинга" Foreground="{StaticResource Muted}" Margin="0,5,0,20"/><TextBlock Text="Интервал, мс" Foreground="#AEB9CB"/><TextBox x:Name="IntervalBox" Text="1000" Margin="0,6,0,15"/><TextBlock Text="Хранить историю, дней" Foreground="#AEB9CB"/><TextBox x:Name="RetentionBox" Text="7" Margin="0,6,0,15"/><CheckBox x:Name="CommandsCheck" Content="Сохранять командные строки" IsChecked="True"/><CheckBox x:Name="NetworkCheck" Content="Показывать TCP-соединения" IsChecked="True"/><CheckBox x:Name="HistoryCheck" Content="Записывать историю на диск" IsChecked="True"/><Button Content="Сохранить изменения" Click="SaveSettingsClick" HorizontalAlignment="Left" Margin="0,18,0,0"/></StackPanel></Border>
                        <StackPanel Grid.Column="2"><Border Style="{StaticResource Card}" Margin="0,0,0,14"><StackPanel><Grid><StackPanel><TextBlock Text="Служба Windows" FontSize="19" FontWeight="SemiBold"/><TextBlock Text="Работает до входа пользователя в систему" Foreground="{StaticResource Muted}" Margin="0,5,0,0"/></StackPanel><Border HorizontalAlignment="Right" Background="#173B32" CornerRadius="12" Padding="10,4"><TextBlock Text="SYSTEM" Foreground="#64D6A4" FontSize="10" FontWeight="Bold"/></Border></Grid><WrapPanel Margin="0,22,0,0"><Button Content="Установить и запустить" Click="EnableServiceClick"/><Button Content="Остановить автозапуск" Background="#263248" Click="DisableServiceClick"/><Button Content="Перезапустить" Background="#263248" Click="RestartServiceClick"/></WrapPanel></StackPanel></Border><Border Style="{StaticResource Card}" Margin="0"><StackPanel><TextBlock Text="Приватность и хранение" FontSize="19" FontWeight="SemiBold"/><TextBlock Text="Нет перехвата клавиатуры, окон или содержимого файлов. Метрики, командные строки и сетевые адреса остаются на этом компьютере." Foreground="{StaticResource Muted}" TextWrapping="Wrap" LineHeight="20" Margin="0,10,0,13"/><TextBlock Text="КАТАЛОГ ДАННЫХ" Style="{StaticResource MetricLabel}"/><TextBlock x:Name="DataPathText" Foreground="#8EA0FF" TextWrapping="Wrap" Margin="0,5,0,0"/></StackPanel></Border></StackPanel>
                    </Grid></ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
