<Window x:Class="SpywareMonitor.Setup.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC Pressure Monitor Setup" Icon="Assets/PressureMonitor.ico" Width="650" Height="470" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Background="#090D17" Foreground="#EEF2FA" FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#EEF2FA"/></Style>
        <Style TargetType="Button"><Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="#6C7CFF"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="22,11"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}"><ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Center"/></Border></ControlTemplate></Setter.Value></Setter></Style>
        <Style TargetType="TextBox"><Setter Property="Background" Value="#0B1220"/><Setter Property="Foreground" Value="#EEF2FA"/><Setter Property="CaretBrush" Value="White"/><Setter Property="BorderBrush" Value="#2A3750"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="10,8"/></Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="82"/><RowDefinition/><RowDefinition Height="88"/></Grid.RowDefinitions>
        <Border Background="#0D1422" BorderBrush="#202A3E" BorderThickness="0,0,0,1"><Grid Margin="26,0"><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Border Width="44" Height="44" CornerRadius="11" Background="#101827" ClipToBounds="True"><Image Source="Assets/PressureMonitor.png" Stretch="UniformToFill"/></Border><StackPanel Margin="13,0,0,0" VerticalAlignment="Center"><TextBlock Text="PC PRESSURE MONITOR" FontSize="17" FontWeight="Bold"/><TextBlock x:Name="HeaderSubtitle" Text="Installing version 1.0.0" Foreground="#8996AC" FontSize="12" Margin="0,3,0,0"/></StackPanel></StackPanel><Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#18233A" CornerRadius="12" Padding="10,4"><TextBlock Text="WINDOWS 10/11" Foreground="#8EA0FF" FontSize="10" FontWeight="Bold"/></Border></Grid></Border>
        <StackPanel Grid.Row="1" Margin="34,26"><TextBlock x:Name="TitleText" Text="Ready to install" FontSize="26" FontWeight="SemiBold"/><TextBlock x:Name="DescriptionText" Text="The desktop interface and system monitoring service will be installed. The service starts automatically with Windows and stores all metrics locally." Foreground="#9AA7BA" FontSize="14" TextWrapping="Wrap" LineHeight="22" Margin="0,10,0,0"/><TextBlock Text="INSTALL LOCATION" Foreground="#71809A" FontSize="10" FontWeight="Bold" Margin="0,18,0,7"/><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="InstallPathBox" Text="C:\Program Files\PC Pressure Monitor"/><Button x:Name="BrowseButton" Grid.Column="1" Content="Browse" Background="#263248" Margin="9,0,0,0" Click="BrowseClick"/></Grid><Grid Margin="0,12,0,0"><TextBlock Text="Local data only" Foreground="#58D49C"/><TextBlock x:Name="SpaceText" Text="" Foreground="#8996AC" HorizontalAlignment="Right"/></Grid><ProgressBar x:Name="Progress" Height="5" Margin="0,20,0,0" IsIndeterminate="True" Visibility="Collapsed" Foreground="#6C7CFF" Background="#202A3E"/><TextBlock x:Name="StatusText" Foreground="#8996AC" Margin="0,9,0,0"/></StackPanel>
        <Border Grid.Row="2" Background="#0D1422" BorderBrush="#202A3E" BorderThickness="0,1,0,0"><StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="25"><Button x:Name="CancelButton" Content="Cancel" Background="#263248" Click="CancelClick"/><Button x:Name="ActionButton" Content="Install" Margin="10,0,0,0" Click="ActionClick"/></StackPanel></Border>
    </Grid>
</Window>
