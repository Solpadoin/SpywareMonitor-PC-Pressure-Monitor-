<Window x:Class="SpywareMonitor.Setup.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC Pressure Monitor Setup" Width="610" Height="430" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Background="#090D17" Foreground="#EEF2FA" FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="#EEF2FA"/></Style>
        <Style TargetType="Button"><Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="#6C7CFF"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="22,11"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}"><ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Center"/></Border></ControlTemplate></Setter.Value></Setter></Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="82"/><RowDefinition/><RowDefinition Height="88"/></Grid.RowDefinitions>
        <Border Background="#0D1422" BorderBrush="#202A3E" BorderThickness="0,0,0,1"><Grid Margin="26,0"><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Border Width="44" Height="44" CornerRadius="11" Background="#6C7CFF"><TextBlock Text="P" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><StackPanel Margin="13,0,0,0" VerticalAlignment="Center"><TextBlock Text="PC PRESSURE MONITOR" FontSize="17" FontWeight="Bold"/><TextBlock x:Name="HeaderSubtitle" Text="Установка версии 1.0.0" Foreground="#8996AC" FontSize="12" Margin="0,3,0,0"/></StackPanel></StackPanel><Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#18233A" CornerRadius="12" Padding="10,4"><TextBlock Text="WINDOWS 10/11" Foreground="#8EA0FF" FontSize="10" FontWeight="Bold"/></Border></Grid></Border>
        <StackPanel Grid.Row="1" Margin="34,30"><TextBlock x:Name="TitleText" Text="Всё готово к установке" FontSize="26" FontWeight="SemiBold"/><TextBlock x:Name="DescriptionText" Text="Будут установлены интерфейс и системная служба мониторинга. Служба запустится автоматически и начнёт собирать локальные метрики после загрузки Windows." Foreground="#9AA7BA" FontSize="14" TextWrapping="Wrap" LineHeight="22" Margin="0,12,0,0"/><Border Background="#101827" CornerRadius="10" Padding="14" Margin="0,22,0,0"><Grid><TextBlock x:Name="LocationText" Text="C:\Program Files\PC Pressure Monitor" Foreground="#B9C4D6"/><TextBlock Text="Только локальные данные" Foreground="#58D49C" HorizontalAlignment="Right"/></Grid></Border><ProgressBar x:Name="Progress" Height="5" Margin="0,25,0,0" IsIndeterminate="True" Visibility="Collapsed" Foreground="#6C7CFF" Background="#202A3E"/><TextBlock x:Name="StatusText" Foreground="#8996AC" Margin="0,10,0,0"/></StackPanel>
        <Border Grid.Row="2" Background="#0D1422" BorderBrush="#202A3E" BorderThickness="0,1,0,0"><StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="25"><Button x:Name="CancelButton" Content="Отмена" Background="#263248" Click="CancelClick"/><Button x:Name="ActionButton" Content="Установить" Margin="10,0,0,0" Click="ActionClick"/></StackPanel></Border>
    </Grid>
</Window>
